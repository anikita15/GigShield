{
  "name": "gigshield-monorepo",
  "version": "1.0.0",
  "description": "GigShield AI — Parametric Insurance Orchestration",
  "main": "index.js",
  "scripts": {
    "start:backend": "cd backend && npm run dev",
    "start:ml": "cd ml-service && python -m uvicorn main:app --port 8000 --reload",
    "start:trigger": "cd trigger-engine && node index.js",
    "start:frontend": "cd frontend && npm run dev -- --port 5173 --strictPort",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:ml\" \"npm run start:trigger\" \"npm run start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "axios": "^1.14.0"
  }
}
